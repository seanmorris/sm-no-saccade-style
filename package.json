{
  "name": "sm-no-saccade-style",
  "license": "Apache-2.0",
  "author": "Sean Morris",
  "version": "0.1.1",
  "description": "ESLint style plugin for left-rail punctuation, Allman blocks, tabs, and tight control parens.",
  "keywords": [
    "eslint",
    "eslintplugin",
    "style",
    "formatting",
    "commas",
    "allman",
    "typescript",
    "seanmorris"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seanmorris/sm-no-saccade-style.git"
  },
  "bugs": {
    "url": "https://github.com/seanmorris/sm-no-saccade-style/issues"
  },
  "homepage": "https://github.com/seanmorris/sm-no-saccade-style#readme",
  "type": "module",
  "exports": {
    ".": "./index.js"
  },
  "files": [
    "index.js",
    "NOTICE",
    "README.md",
    "source/index.js",
    "source/rules"
  ],
  "scripts": {
    "lint": "eslint index.js source/**/*.js test/**/*.js eslint.config.js",
    "lint:fix": "eslint index.js source/**/*.js test/**/*.js eslint.config.js --fix",
    "prepublishOnly": "npm run lint && npm test",
    "test": "node ./test/run.js",
    "coverage": "c8 --reporter=text-summary --reporter=text --reporter=lcov node ./test/run.js",
    "lint:fixtures": "eslint test-fixtures --fix"
  },
  "dependencies": {
    "@stylistic/eslint-plugin": "^2.11.0",
    "@typescript-eslint/parser": "^8.46.2"
  },
  "devDependencies": {
    "c8": "^10.1.3",
    "eslint": "^9.26.0"
  }
}
